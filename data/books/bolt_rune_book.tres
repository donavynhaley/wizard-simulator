[ext_resource type="Resource" path="res://data/runes/templates/bolt/bolt_template_02.tres" id="4_bolt_template"]

[sub_resource type="Resource" id="BookPageData_bolt_intro"]
script = ExtResource("2_page_data")
title = "Bolt Rune"
body = "Category: Form

Trace the strokes shown on the facing page in order.
Use this form when a spell should travel outward from the caster as a direct projectile."

[sub_resource type="Resource" id="BookPageData_bolt_rune"]
script = ExtResource("2_page_data")
title = "Scribing Pattern"
body = "Watch the glowing tip, then copy each stroke in order on the form section of the scroll."
rune_template = ExtResource("4_bolt_template")

[sub_resource type="Resource" id="BookSpreadData_bolt_first"]
script = ExtResource("3_spread_data")
left_page = SubResource("BookPageData_bolt_intro")
right_page = SubResource("BookPageData_bolt_rune")

[resource]
script = ExtResource("1_book_data")
id = "bolt_rune_book"
title = "Bolt Rune Book"
display_name = "Bolt Rune Book"
spreads = Array[ExtResource("3_spread_data")]([SubResource("BookSpreadData_bolt_first")])
